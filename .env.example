# --- Database (Supabase Postgres) -------------------------------------------
# Supabase: Project Settings → Database → Connection string → "Direct connection"
# (host db.<ref>.supabase.co, port 5432). URL-encode special chars in the password.
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require"

# --- Admin auth --------------------------------------------------------------
ADMIN_PASSWORD="change-this-to-a-strong-password"
# Random string used to sign the admin session cookie (e.g. `openssl rand -hex 32`)
ADMIN_SECRET="change-this-random-secret"

# --- Public site config ------------------------------------------------------
# Full origin, no trailing slash. Used to build invite + godparent QR URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Google Maps Embed API key. Without it, maps use the keyless fallback.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
